struct block_tqk_flex_metal { uint8_t _dummy; };

// Generic bit unpacking from device memory: extract 'bits'-wide value at index 'idx'
// Uses uint32_t accumulator to avoid signed-promotion edge cases on GPU compilers.
inline int flex_unpack_metal(device const uint8_t * buf, int idx, int bits) {
    int bp = idx * bits;
    int bi = bp / 8;
    int sh = bp % 8;
    uint32_t val = (uint32_t)buf[bi];
    if (sh + bits > 8)  val |= (uint32_t)buf[bi + 1] << 8;
    if (sh + bits > 16) val |= (uint32_t)buf[bi + 2] << 16;
    return (int)((val >> sh) & ((1u << bits) - 1u));
}

// Generic bit packing to device memory: pack 'bits'-wide value at index 'idx'
// IMPORTANT: caller must zero the buffer before first use
inline void flex_pack_metal(device uint8_t * buf, int idx, int val, int bits) {
    int bp = idx * bits;
    int bi = bp / 8;
    int sh = bp % 8;
    int v = val & ((1 << bits) - 1);
    buf[bi] |= (uint8_t)(v << sh);
    if (sh + bits > 8)  buf[bi + 1] |= (uint8_t)(v >> (8 - sh));
    if (sh + bits > 16) buf[bi + 2] |= (uint8_t)(v >> (16 - sh));
}

// Centroid lookup for d=32 by bit width
inline float flex_centroid_d32(int idx, int bits) {
    switch (bits) {
        case 2: return tq_c4_d32[idx];
        case 3: return tq_c8_d32[idx];
        case 4: return tq_c16_d32[idx];
        case 5: return tq_c32_d32[idx];
        case 6: return tq_c64_d32[idx];
        case 7: return tq_c128_d32[idx];
        case 8: return tq_c256_d32[idx];
        case 9: return tq_c512_d32[idx];
        case 10: return tq_c1024_d32[idx];
        default: return 0.0f;
    }
}

inline float flex_centroid_d96(int idx, int bits) {
    switch (bits) {
        case 1: return tq_c2_d96[idx];
        case 2: return tq_c4_d96[idx];
        case 3: return tq_c8_d96[idx];
        case 4: return tq_c16_d96[idx];
        case 5: return tq_c32_d96[idx];
        case 6: return tq_c64_d96[idx];
        case 7: return tq_c128_d96[idx];
        case 8: return tq_c256_d96[idx];
        default: return 0.0f;
    }
}

inline float flex_centroid_d128(int idx, int bits) {
    switch (bits) {
        case 3: return tq_c8_d128[idx];
        case 4: return tq_c16_d128[idx];
        case 5: return tq_c32_d128[idx];
        case 6: return tq_c64_d128[idx];
        case 7: return tq_c128_d128[idx];
        case 8: return tq_c256_d128[idx];
        case 9: return tq_c512_d128[idx];
        case 10: return tq_c1024_d128[idx];
        default: return 0.0f;
    }
}

// ---------------------------------------------------------------------------
// Structured rotation for non-power-of-2 lo-blocks (96=3×32, 192=3×64)
// R = (I_3 ⊗ H_block) · P · (I_block ⊗ O_3) · D
// ---------------------------------------------------------------------------

constant float tq_O3[9] = {
    0.5773502691896257f,  0.5773502691896257f,  0.5773502691896257f,
    0.7071067811865476f,  0.0f,                -0.7071067811865476f,
    0.4082482904638631f, -0.8164965809277261f,  0.4082482904638631f,
};

inline float tq_struct_sign(int i, int n) {
    ulong seed = (n == 96) ? 0x5452534C4F393600ULL : 0x5452534C31393200ULL;
    for (int k = 0; k <= i; k++) {
        seed = seed * 6364136223846793005ULL + 1442695040888963407ULL;
    }
    return ((uint(seed >> 32)) & 1) ? -1.0f : 1.0f;
}

template<int N, int BLOCK>
inline void tq_structured_rotate_lo(thread float * x) {
    for (int i = 0; i < N; i++) x[i] *= tq_struct_sign(i, N);
    for (int j = 0; j < BLOCK; j++) {
        float a = x[j], b = x[BLOCK + j], c = x[2*BLOCK + j];
        x[j]          = tq_O3[0]*a + tq_O3[1]*b + tq_O3[2]*c;
        x[BLOCK + j]  = tq_O3[3]*a + tq_O3[4]*b + tq_O3[5]*c;
        x[2*BLOCK + j]= tq_O3[6]*a + tq_O3[7]*b + tq_O3[8]*c;
    }
    float tmp[N];
    for (int i = 0; i < N; i++) tmp[(35*i + 17) % N] = x[i];
    for (int i = 0; i < N; i++) x[i] = tmp[i];
    tq_fwht<BLOCK>(x);
    tq_fwht<BLOCK>(x + BLOCK);
    tq_fwht<BLOCK>(x + 2*BLOCK);
}

template<int N, int BLOCK>
inline void tq_structured_unrotate_lo(thread float * x) {
    tq_fwht<BLOCK>(x);
    tq_fwht<BLOCK>(x + BLOCK);
    tq_fwht<BLOCK>(x + 2*BLOCK);
    float tmp[N];
    for (int i = 0; i < N; i++) tmp[i] = x[(35*i + 17) % N];
    for (int i = 0; i < N; i++) x[i] = tmp[i];
    for (int j = 0; j < BLOCK; j++) {
        float a = x[j], b = x[BLOCK + j], c = x[2*BLOCK + j];
        x[j]          = tq_O3[0]*a + tq_O3[3]*b + tq_O3[6]*c;
        x[BLOCK + j]  = tq_O3[1]*a + tq_O3[4]*b + tq_O3[7]*c;
        x[2*BLOCK + j]= tq_O3[2]*a + tq_O3[5]*b + tq_O3[8]*c;
    }
    for (int i = 0; i < N; i++) x[i] *= tq_struct_sign(i, N);
}

// Bit unpacking: 3-bit and 4-bit from device memory
inline int tq_up3(device const uint8_t * q, int j) {
    int bp = j * 3, bi = bp >> 3, sh = bp & 7;
    return (sh <= 5) ? (q[bi] >> sh) & 7 : ((q[bi] >> sh) | (q[bi+1] << (8 - sh))) & 7;
}
inline int tq_up4(device const uint8_t * q, int j) {
    return (q[j / 2] >> ((j % 2) * 4)) & 0xF;
}
inline int tq_up2(device const uint8_t * q, int j) {
    return (q[j / 4] >> ((j % 4) * 2)) & 3;
}
inline int tq_up1(device const uint8_t * q, int j) {
    return (q[j / 8] >> (j % 8)) & 1;
}
inline int tq_up5(device const uint8_t * q, int j) {
    int bp = j * 5, bi = bp >> 3, sh = bp & 7;
    int v = q[bi] >> sh;
    if (sh > 3) v |= q[bi+1] << (8 - sh);
    return v & 0x1F;
}

// Bit packing: 3-bit and 4-bit to thread memory
inline void tq_pk3(thread uint8_t * q, int j, int v) {
    int bp = j * 3, bi = bp >> 3, sh = bp & 7;
    q[bi] |= (uint8_t)((v << sh) & 0xFF);
    if (sh > 5) q[bi+1] |= (uint8_t)(v >> (8 - sh));
}
inline void tq_pk4(thread uint8_t * q, int j, int v) {
    q[j / 2] |= (uint8_t)(v << ((j % 2) * 4));
}

// Bit packing: device memory overloads (for set_rows kernels)
inline void tq_pk3(device uint8_t * q, int j, int v) {
    int bp = j * 3, bi = bp >> 3, sh = bp & 7;
    q[bi] |= (uint8_t)((v << sh) & 0xFF);
    if (sh > 5) q[bi+1] |= (uint8_t)(v >> (8 - sh));
}
inline void tq_pk4(device uint8_t * q, int j, int v) {
    q[j / 2] |= (uint8_t)(v << ((j % 2) * 4));
}

inline void tq_pk2(device uint8_t * q, int j, int v) {
    q[j / 4] |= (uint8_t)(v << ((j % 4) * 2));
}
inline void tq_pk1(device uint8_t * q, int j, int v) {
    q[j / 8] |= (uint8_t)(v << (j % 8));
}

// Nearest centroid search
inline int tq_nearest(float val, constant float * c, int n) {
    int best = 0;
    float bd = abs(val - c[0]);
    for (int i = 1; i < n; i++) {
        float d = abs(val - c[i]);
        if (d < bd) { bd = d; best = i; }
    }
    return best;
}

inline int flex_nearest_d32(float val, int bits) {
    switch (bits) {
        case 2: return tq_nearest(val, tq_c4_d32, 4);
        case 3: return tq_nearest(val, tq_c8_d32, 8);
        case 4: return tq_nearest(val, tq_c16_d32, 16);
        case 5: return tq_nearest(val, tq_c32_d32, 32);
        case 6: return tq_nearest(val, tq_c64_d32, 64);
        case 7: return tq_nearest(val, tq_c128_d32, 128);
        case 8: return tq_nearest(val, tq_c256_d32, 256);
        case 9: return tq_nearest(val, tq_c512_d32, 512);
        case 10: return tq_nearest(val, tq_c1024_d32, 1024);
        default: return 0;
    }
}

inline int flex_nearest_d96(float val, int bits) {
    switch (bits) {
        case 1: return tq_nearest(val, tq_c2_d96, 2);
        case 2: return tq_nearest(val, tq_c4_d96, 4);
        case 3: return tq_nearest(val, tq_c8_d96, 8);
        case 4: return tq_nearest(val, tq_c16_d96, 16);
        case 5: return tq_nearest(val, tq_c32_d96, 32);
        case 6: return tq_nearest(val, tq_c64_d96, 64);
        case 7: return tq_nearest(val, tq_c128_d96, 128);
        case 8: return tq_nearest(val, tq_c256_d96, 256);
        default: return 0;
    }
}

// Nearest centroid search for d=128 by bit width
inline int flex_nearest_d128(float val, int bits) {
    switch (bits) {
        case 3: return tq_nearest(val, tq_c8_d128, 8);
        case 4: return tq_nearest(val, tq_c16_d128, 16);
        case 5: return tq_nearest(val, tq_c32_d128, 32);
        case 6: return tq_nearest(val, tq_c64_d128, 64);
        case 7: return tq_nearest(val, tq_c128_d128, 128);
        case 8: return tq_nearest(val, tq_c256_d128, 256);
        case 9: return tq_nearest(val, tq_c512_d128, 512);
        case 10: return tq_nearest(val, tq_c1024_d128, 1024);
        default: return 0;
    }
}

