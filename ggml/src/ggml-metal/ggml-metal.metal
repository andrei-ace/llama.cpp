    thread float hi_raw[64], lo_raw[192];
    for (int j = 0; j < 64; j++)  hi_raw[j] = src[perm[j]];
    for (int j = 0; j < 192; j++) lo_raw[j] = src[perm[64+j]];
    thread float hi_rot[64], lo_rot[192];
    for (int j = 0; j < 64; j++) hi_rot[j] = hi_raw[j]; tq_fwht<64>(hi_rot);
    for (int j = 0; j < 192; j++) lo_rot[j] = lo_raw[j]; tq_structured_rotate_lo<192, 64>(lo_rot);
    float sum_hi=0, sum_lo=0;
    for (int j=0;j<64;j++) sum_hi+=hi_rot[j]*hi_rot[j];
    for (int j=0;j<192;j++) sum_lo+=lo_rot[j]*lo_rot[j];
    float norm_hi=sqrt(sum_hi), norm_lo=sqrt(sum_lo);
    device block_tqk_2hi_1lo_d256 * blk = (device block_tqk_2hi_1lo_d256 *)((device char *)dst + i1*args.nb1 + i02*args.nb2 + i03*args.nb3) + iblk;
    blk->norm_hi=half(norm_hi); blk->norm_lo=half(norm_lo); blk->rnorm_hi=half(0); blk->rnorm_lo=half(0);
    if (norm_hi==0 && norm_lo==0) {
        for (int j=0;j<16;j++) blk->qs_hi[j]=0; for (int j=0;j<24;j++) blk->qs_lo[j]=0;
        for (int j=0;j<8;j++) blk->signs_hi[j]=0; for (int j=0;j<24;j++) blk->signs_lo[j]=0;
        return;
    }
    float inv_hi=(norm_hi>1e-12f)?1.0f/norm_hi:0, inv_lo=(norm_lo>1e-12f)?1.0f/norm_lo:0;
    for (int j=0;j<16;j++) blk->qs_hi[j]=0;
    for (int j=0;j<64;j++) tq_pk2((device uint8_t*)blk->qs_hi, j, tq_nearest(hi_rot[j]*inv_hi, tq_c4_d64, 4));
    for (int j=0;j<24;j++) blk->qs_lo[j]=0;
    for (int j=0;j<192;j++) tq_pk1((device uint8_t*)blk->qs_lo, j, tq_nearest(lo_rot[j]*inv_lo, tq_c2_d192, 2));
    // QJL on hi
    thread float yhi[64]; for (int j=0;j<64;j++) yhi[j]=tq_c4_d64[tq_up2(blk->qs_hi,j)];
    thread float hi_rec[64]; for (int j=0;j<64;j++) hi_rec[j]=yhi[j]; tq_fwht<64>(hi_rec);
    thread float r_hi[64]; for (int j=0;j<64;j++) r_hi[j]=hi_raw[j]-norm_hi*hi_rec[j];
    float rn_hi=0; for (int j=0;j<64;j++) rn_hi+=r_hi[j]*r_hi[j]; tq_fwht<64>(r_hi);
    for (int j=0;j<8;j++) blk->signs_hi[j]=0;
    for (int j=0;j<64;j++) { if (r_hi[j]>=0) blk->signs_hi[j/8]|=(uint8_t)(1<<(j%8)); }
    blk->rnorm_hi=half(sqrt(rn_hi));
    // QJL on lo (residual in rotated space — per-element sign, no FWHT)
    thread float ylo[192]; for (int j=0;j<192;j++) ylo[j]=tq_c2_d192[tq_up1(blk->qs_lo,j)];
    thread float r_lo[192]; for (int j=0;j<192;j++) r_lo[j]=lo_rot[j]-norm_lo*ylo[j];
    float rn_lo=0; for (int j=0;j<192;j++) rn_lo+=r_lo[j]*r_lo[j];
    for (int j=0;j<24;j++) blk->signs_lo[j]=0;
    for (int j=0;j<192;j++) { if (r_lo[j]>=0) blk->signs_lo[j/8]|=(uint8_t)(1<<(j%8)); }
    blk->rnorm_lo=half(sqrt(rn_lo));
}

// 3hi_2lo_had_d256: get_rows (3-bit hi + QJL, 2-bit lo + QJL, channel map)
[[host_name("kernel_get_rows_3hi_2lo_had_d256")]]
kernel void kernel_get_rows_3hi_2lo_had_d256(
        constant ggml_metal_kargs_get_rows & args,
        device const void    * src0,
        device const void    * src1,
        device       float   * dst,
        device const int32_t * tq_chmap,
        constant int32_t & tq_layer_idx,
        constant int32_t & tq_n_kv_heads,
        uint3 tgpig[[threadgroup_position_in_grid]],
        ushort tiitg[[thread_index_in_threadgroup]]) {
    const int i10 = tgpig.x; const int i02 = tgpig.y; const int i03 = tgpig.z;
    const int64_t r = ((const device int64_t *)((const device char *)src1 + i10*args.nb10))[0];
    const int iblk = tiitg;
    if (iblk >= args.ne00 / 256) return;
    device const block_tqk_3hi_2lo_d256 * blk = (device const block_tqk_3hi_2lo_d256 *)
        ((const device char *)src0 + i03*args.nb03 + i02*args.nb02 + r*args.nb01) + iblk;
    device const int32_t * perm = tq_chmap + (tq_layer_idx * tq_n_kv_heads + iblk) * 256;
    float norm_hi = float(blk->norm_hi), norm_lo = float(blk->norm_lo);
    float rnorm_hi = float(blk->rnorm_hi), rnorm_lo = float(blk->rnorm_lo);
    thread float hi[64];
    for (int j = 0; j < 64; j++) hi[j] = tq_c8_d64[tq_up3(blk->qs_hi, j)];
    tq_fwht<64>(hi);
    thread float corr_hi[64];
    for (int j = 0; j < 64; j++) corr_hi[j] = ((blk->signs_hi[j/8] >> (j%8)) & 1) ? 1.0f : -1.0f;
    tq_fwht<64>(corr_hi);
    float qjl_s_hi = 1.2533141f / 64.0f * rnorm_hi;
    for (int j = 0; j < 64; j++) hi[j] = norm_hi * hi[j] + qjl_s_hi * corr_hi[j];
    thread float lo[192];
    for (int j = 0; j < 192; j++) lo[j] = tq_c4_d192[tq_up2(blk->qs_lo, j)] * norm_lo;
    float qjl_s_lo = 1.2533141f / 192.0f * rnorm_lo;
    for (int j = 0; j < 192; j++) {
        float sign = ((blk->signs_lo[j/8] >> (j%8)) & 1) ? 1.0f : -1.0f;
        lo[j] += qjl_s_lo * sign;
    }
    tq_structured_unrotate_lo<192, 64>(lo);
    device float * out = dst + (i10*args.ne00 + iblk*256) + i02*args.nb2/4 + i03*args.nb3/4;
    for (int j = 0; j < 64; j++)  out[perm[j]] = hi[j];
    for (int j = 0; j < 192; j++) out[perm[64+j]] = lo[j];
}

// TQK_FLEX: get_rows (full dequant with inverse rotation + optional QJL)
// Uses constant arguments (not function constants) for runtime configuration.
[[host_name("kernel_get_rows_flex")]]
kernel void kernel_get_rows_flex(
        constant ggml_metal_kargs_get_rows & args,
        device const void      * src0,
        device const void      * src1,
        device       float     * dst,
        device const int32_t   * tq_chmap,
        constant int32_t & tq_layer_idx,
        constant int32_t & tq_n_kv_heads,
        constant int32_t & flex_hi_bits,
        constant int32_t & flex_lo_bits,
        constant int32_t & flex_hi_res_bits,
        constant int32_t & flex_qjl_hi,
        constant int32_t & flex_qjl_lo,
        constant int32_t & flex_split,
        constant int32_t & flex_block_bytes,
        uint3 tgpig[[threadgroup_position_in_grid]],
        ushort tiitg[[thread_index_in_threadgroup]]) {
    const int i10 = tgpig.x;
    const int i02 = tgpig.y;
    const int i03 = tgpig.z;
    const int64_t r = ((const device int64_t *)((const device char *)src1 + i10*args.nb10))[0];
    const int iblk = tiitg;
    if (iblk >= args.ne00 / 128) return;

    const int blk_stride = args.nb01 / (args.ne00 / 128); // per-head stride in src
    device const uint8_t * raw = (device const uint8_t *)
        ((const device char *)src0 + i03*args.nb03 + i02*args.nb02 + r*args.nb01) + iblk * blk_stride;

    device float * out = dst + (i10*args.ne00 + iblk*128) + i02*args.nb2/4 + i03*args.nb3/4;

    if (flex_split) {
        // Split mode: permute + 4xFWHT_32 (bare rotation on lo, like _sj)
        device const int32_t * perm = tq_chmap + (tq_layer_idx * tq_n_kv_heads + iblk) * 128;

        float norm_hi = float(*(device const half *)(raw));
        float norm_lo = float(*(device const half *)(raw + 2));
        int off = 4;

        int off_qs_hi = off;
        int qs_hi_bytes = (32 * flex_hi_bits + 7) / 8;
        off += qs_hi_bytes;

        int off_qs_lo = off;
        int qs_lo_bytes = (96 * flex_lo_bits + 7) / 8;
        off += qs_lo_bytes;

        int off_rnorm_res = off;
        int off_qs_hi2 = off + 2;
        if (flex_hi_res_bits > 0) {
            off += 2 + (32 * flex_hi_res_bits + 7) / 8;
        }

        int off_rnorm_qjl_hi = off;
        int off_signs_hi = off + 2;
        if (flex_qjl_hi) {
            off += 2 + 4;
        }

        int off_rnorm_qjl_lo = off;
        int off_signs_lo = off + 2;

        // Dequant hi: centroid lookup in rotated space
        thread float hi[32];
        for (int j = 0; j < 32; j++) {
            hi[j] = flex_centroid_d32(
                flex_unpack_metal(raw + off_qs_hi, j, flex_hi_bits), flex_hi_bits);
        }

        // Optional: add residual MSE layer (in rotated space)
        if (flex_hi_res_bits > 0) {
            float rn2 = float(*(device const half *)(raw + off_rnorm_res));
            float inv_norm = (norm_hi > 1e-12f) ? rn2 / norm_hi : 0.0f;
            for (int j = 0; j < 32; j++) {
                hi[j] += inv_norm * flex_centroid_d32(
                    flex_unpack_metal(raw + off_qs_hi2, j, flex_hi_res_bits), flex_hi_res_bits);
            }
        }

        // Inverse FWHT to get back to raw space, then scale
        tq_fwht<32>(hi);

        // QJL correction on hi (FWHT-projected signs)
        if (flex_qjl_hi) {
            float rnorm_hi = float(*(device const half *)(raw + off_rnorm_qjl_hi));
            thread float corr[32];
            for (int j = 0; j < 32; j++) {
                corr[j] = ((raw[off_signs_hi + j / 8] >> (j % 8)) & 1) ? 1.0f : -1.0f;
            }
            tq_fwht<32>(corr);
            float qjl_s = 1.2533141f / 32.0f * rnorm_hi;
            for (int j = 0; j < 32; j++) {
                hi[j] = norm_hi * hi[j] + qjl_s * corr[j];
            }
        } else {
            for (int j = 0; j < 32; j++) hi[j] *= norm_hi;
        }

        // Dequant lo: centroid lookup, scale, then inverse bare 3xFWHT_32
        thread float lo[96];
        for (int j = 0; j < 96; j++) {
            lo[j] = flex_centroid_d96(
                flex_unpack_metal(raw + off_qs_lo, j, flex_lo_bits), flex_lo_bits) * norm_lo;
        }

        // QJL correction on lo (per-element sign, in rotated space)
        if (flex_qjl_lo) {
            float rnorm_lo = float(*(device const half *)(raw + off_rnorm_qjl_lo));
            float qjl_s_lo = 1.2533141f / 96.0f * rnorm_lo;
            for (int j = 0; j < 96; j++) {
                float sign = ((raw[off_signs_lo + j / 8] >> (j % 8)) & 1) ? 1.0f : -1.0f;
                lo[j] += qjl_s_lo * sign;
            }
        }

        // Inverse bare rotation: 3xFWHT_32
        tq_fwht<32>(lo); tq_fwht<32>(lo + 32); tq_fwht<32>(lo + 64);

        // Inverse permutation: place channels back in original positions
        for (int j = 0; j < 32; j++)  out[perm[j]]      = hi[j];
        for (int j = 0; j < 96; j++)  out[perm[32 + j]]  = lo[j];
    } else {
        // Non-split mode: full FWHT_128
        float norm = float(*(device const half *)(raw));
        int off = 2;

        int off_qs = off;
        int qs_bytes = (128 * flex_hi_bits + 7) / 8;
        off += qs_bytes;

        int off_rnorm_qjl = off;
        int off_signs = off + 2;

        thread float rot[128];
        for (int j = 0; j < 128; j++) {
            rot[j] = flex_centroid_d128(
                flex_unpack_metal(raw + off_qs, j, flex_hi_bits), flex_hi_bits);
        }
        tq_fwht<128>(rot);

        if (flex_qjl_hi) {
            float rnorm = float(*(device const half *)(raw + off_rnorm_qjl));
            // QJL on full 128-dim: signs are FWHT-projected
            thread float corr[128];
            for (int j = 0; j < 128; j++) {
                corr[j] = ((raw[off_signs + j / 8] >> (j % 8)) & 1) ? 1.0f : -1.0f;
            }
            tq_fwht<128>(corr);
            float qjl_s = 1.2533141f / 128.0f * rnorm;
            for (int j = 0; j < 128; j++) {
                out[j] = norm * rot[j] + qjl_s * corr[j];
            }
        } else {
            for (int j = 0; j < 128; j++) {
                out[j] = norm * rot[j];
            }
        }
    }
}


