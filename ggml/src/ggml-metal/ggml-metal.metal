        int j = il * 4 + i;
        if (j < 32) {
            float norm_hi = float(xb->norm_hi);
            float rnorm2  = float(xb->rnorm2_hi);
            int v1 = tq_up5(xb->qs_hi, j);
            int v2 = tq_up3(xb->qs_hi2, j);
            reg[i] = norm_hi * tq_c32_d32[v1] + rnorm2 * tq_c8_d32[v2];
        } else {
            float norm_lo = float(xb->norm_lo);
            int lo_j = j - 32;
            reg[i] = norm_lo * tq_c8_d96[tq_up3(xb->qs_lo, lo_j)];
        }
    }
}


// TQK_FLEX function constants for Flash Attention
constant bool    FC_flex_split       [[function_constant(FC_TQ_FLEX + 0)]];
constant int32_t FC_flex_hi_bits     [[function_constant(FC_TQ_FLEX + 1)]];
constant int32_t FC_flex_lo_bits     [[function_constant(FC_TQ_FLEX + 2)]];
constant int32_t FC_flex_hi_res_bits [[function_constant(FC_TQ_FLEX + 3)]];
constant bool    FC_flex_qjl_hi      [[function_constant(FC_TQ_FLEX + 4)]];
constant bool    FC_flex_qjl_lo      [[function_constant(FC_TQ_FLEX + 5)]];

// TQK_FLEX: FA dequantize — runtime-configurable split/non-split with
// variable bit widths, optional hi residual, optional QJL on hi and lo.
// Works in the ROTATED domain — no inverse rotation needed.
// Each call dequants 16 elements (one tile row).
//
// SPLIT layout (FC_flex_split = true):
//   [norm_hi: 2B][norm_lo: 2B]
//   [qs_hi: ceil(32*hi_bits/8)]
//   [qs_lo: ceil(96*lo_bits/8)]
//   Optional: [rnorm_res: 2B][qs_hi2: ceil(32*res_bits/8)]   if hi_res_bits > 0
//   Optional: [rnorm_qjl_hi: 2B][signs_hi: 4B]               if qjl_hi
//   Optional: [rnorm_qjl_lo: 2B][signs_lo: 12B]              if qjl_lo
//
// NON-SPLIT layout (FC_flex_split = false):
//   [norm: 2B]
//   [qs: ceil(128*hi_bits/8)]
//   Optional: [rnorm_qjl: 2B][signs: 16B]                    if qjl_hi

template <typename type4x4>
void dequantize_flex(device const block_tqk_flex_metal * xb, short il, thread type4x4 & reg) {
    device const uint8_t * raw = (device const uint8_t *)xb;

    float4x4 reg_f;

    if (FC_flex_split) {
        // Split mode: 32 hi channels + 96 lo channels
        half norm_hi = *(device const half *)(raw);
        half norm_lo = *(device const half *)(raw + 2);
        int off = 4;

        int off_qs_hi = off;
        int qs_hi_bytes = (32 * FC_flex_hi_bits + 7) / 8;
        off += qs_hi_bytes;

        int off_qs_lo = off;
        int qs_lo_bytes = (96 * FC_flex_lo_bits + 7) / 8;
        off += qs_lo_bytes;

        // Hi residual MSE (optional)
        int off_rnorm_res = off;
        int off_qs_hi2 = off + 2;
        if (FC_flex_hi_res_bits > 0) {
            off += 2 + (32 * FC_flex_hi_res_bits + 7) / 8;
        }

        // QJL on hi (optional)
        int off_rnorm_qjl_hi = off;
        int off_signs_hi = off + 2;
        if (FC_flex_qjl_hi) {
            off += 2 + 4; // 2B norm + 4B signs (32 bits = 4 bytes)
        }

        // QJL on lo (optional)
        int off_rnorm_qjl_lo = off;
        int off_signs_lo = off + 2;
        // (no need to advance off further — this is the last field)

        for (int i = 0; i < 16; i++) {
            int j = il * 16 + i;
            float val;

            if (j < 32) {
                // Hi channels: MSE centroid in d=32 space
                val = float(norm_hi) * flex_centroid_d32(
                    flex_unpack_metal(raw + off_qs_hi, j, FC_flex_hi_bits),
                    FC_flex_hi_bits);

                // Optional: add residual MSE layer
                if (FC_flex_hi_res_bits > 0) {
                    float rn2 = float(*(device const half *)(raw + off_rnorm_res));
                    val += rn2 * flex_centroid_d32(
                        flex_unpack_metal(raw + off_qs_hi2, j, FC_flex_hi_res_bits),
                        FC_flex_hi_res_bits);
                }

                // Optional: add QJL correction on hi
                if (FC_flex_qjl_hi) {
                    float rn = float(*(device const half *)(raw + off_rnorm_qjl_hi));
                    float sign = ((raw[off_signs_hi + j / 8] >> (j % 8)) & 1) ? 1.0f : -1.0f;
                    val += 1.2533141f / 32.0f * rn * sign;
                }
            } else {
                // Lo channels: MSE centroid in d=96 space
                int lo_j = j - 32;
                val = float(norm_lo) * flex_centroid_d96(
                    flex_unpack_metal(raw + off_qs_lo, lo_j, FC_flex_lo_bits),
                    FC_flex_lo_bits);

                // Optional: add QJL correction on lo
                if (FC_flex_qjl_lo) {
                    float rn = float(*(device const half *)(raw + off_rnorm_qjl_lo));
                    float sign = ((raw[off_signs_lo + lo_j / 8] >> (lo_j % 8)) & 1) ? 1.0f : -1.0f;
                    val += 1.2533141f / 96.0f * rn * sign;
                }
            }

            reg_f[i / 4][i % 4] = val;
        }
    } else {
        // Non-split mode: full 128-dim FWHT
        half norm = *(device const half *)(raw);
        int off = 2;

        int off_qs = off;
        int qs_bytes = (128 * FC_flex_hi_bits + 7) / 8;
        off += qs_bytes;

        // QJL on full vector (optional, uses qjl_hi flag)
        int off_rnorm_qjl = off;
        int off_signs = off + 2;

        for (int i = 0; i < 16; i++) {
            int j = il * 16 + i;
            float val = float(norm) * flex_centroid_d128(
                flex_unpack_metal(raw + off_qs, j, FC_flex_hi_bits),
                FC_flex_hi_bits);

            // Optional: add QJL correction
            if (FC_flex_qjl_hi) {
                float rn = float(*(device const half *)(raw + off_rnorm_qjl));
                float sign = ((raw[off_signs + j / 8] >> (j % 8)) & 1) ? 1.0f : -1.0f;
                val += 1.2533141f / 128.0f * rn * sign;
            }

            reg_f[i / 4][i % 4] = val;
        }
    }

    reg = (type4x4) reg_f;
}

// type4 variant: dequantize 4 elements at a time (for FA vec path)
template <typename type4>
void dequantize_flex_t4(device const block_tqk_flex_metal * xb, short il, thread type4 & reg) {
    device const uint8_t * raw = (device const uint8_t *)xb;

    if (FC_flex_split) {
        half norm_hi = *(device const half *)(raw);
        half norm_lo = *(device const half *)(raw + 2);
        int off = 4;

        int off_qs_hi = off;
        int qs_hi_bytes = (32 * FC_flex_hi_bits + 7) / 8;
        off += qs_hi_bytes;

        int off_qs_lo = off;
        int qs_lo_bytes = (96 * FC_flex_lo_bits + 7) / 8;
        off += qs_lo_bytes;

        int off_rnorm_res = off;
        int off_qs_hi2 = off + 2;
        if (FC_flex_hi_res_bits > 0) {
            off += 2 + (32 * FC_flex_hi_res_bits + 7) / 8;
        }

        int off_rnorm_qjl_hi = off;
        int off_signs_hi = off + 2;
        if (FC_flex_qjl_hi) {
            off += 2 + 4;
        }

        int off_rnorm_qjl_lo = off;
        int off_signs_lo = off + 2;

        for (int i = 0; i < 4; i++) {
            int j = il * 4 + i;
            float val;

            if (j < 32) {
                val = float(norm_hi) * flex_centroid_d32(
                    flex_unpack_metal(raw + off_qs_hi, j, FC_flex_hi_bits),
                    FC_flex_hi_bits);

                if (FC_flex_hi_res_bits > 0) {
                    float rn2 = float(*(device const half *)(raw + off_rnorm_res));
                    val += rn2 * flex_centroid_d32(
                        flex_unpack_metal(raw + off_qs_hi2, j, FC_flex_hi_res_bits),
                        FC_flex_hi_res_bits);
                }

                if (FC_flex_qjl_hi) {
                    float rn = float(*(device const half *)(raw + off_rnorm_qjl_hi));
                    float sign = ((raw[off_signs_hi + j / 8] >> (j % 8)) & 1) ? 1.0f : -1.0f;
                    val += 1.2533141f / 32.0f * rn * sign;
                }
            } else {
                int lo_j = j - 32;
                val = float(norm_lo) * flex_centroid_d96(
                    flex_unpack_metal(raw + off_qs_lo, lo_j, FC_flex_lo_bits),
                    FC_flex_lo_bits);

                if (FC_flex_qjl_lo) {
                    float rn = float(*(device const half *)(raw + off_rnorm_qjl_lo));
                    float sign = ((raw[off_signs_lo + lo_j / 8] >> (lo_j % 8)) & 1) ? 1.0f : -1.0f;
                    val += 1.2533141f / 96.0f * rn * sign;
                }
            }

            reg[i] = val;
        }
    } else {
        half norm = *(device const half *)(raw);
        int off = 2;

        int off_qs = off;
        int qs_bytes = (128 * FC_flex_hi_bits + 7) / 8;
        off += qs_bytes;

        int off_rnorm_qjl = off;
        int off_signs = off + 2;

        for (int i = 0; i < 4; i++) {
            int j = il * 4 + i;
            float val = float(norm) * flex_centroid_d128(
                flex_unpack_metal(raw + off_qs, j, FC_flex_hi_bits),
                FC_flex_hi_bits);

            if (FC_flex_qjl_hi) {
                float rn = float(*(device const half *)(raw + off_rnorm_qjl));
                float sign = ((raw[off_signs + j / 8] >> (j % 8)) & 1) ? 1.0f : -1.0f;
                val += 1.2533141f / 128.0f * rn * sign;
            }

            reg[i] = val;
        }
    }
}


