    for (int j = 0; j < 72; j++) blk->qs_lo[j] = 0;
    for (int j = 0; j < 192; j++) {
        tq_pk3((device uint8_t *)blk->qs_lo, j, tq_nearest(lo_rot[j] * inv_lo, tq_c8_d192, 8));
