// 3hi_2lo_had_d256: set_rows (3-bit hi + QJL, 2-bit lo + QJL, channel map)
[[host_name("kernel_set_rows_3hi_2lo_had_d256_i32")]]
kernel void kernel_set_rows_3hi_2lo_had_d256(
        constant ggml_metal_kargs_set_rows & args,
        device const void  * src0, device const void  * src1, device void * dst,
        device const int32_t * tq_chmap,
        constant int32_t & tq_layer_idx, constant int32_t & tq_n_kv_heads,
        uint3 tgpig[[threadgroup_position_in_grid]], ushort tiitg[[thread_index_in_threadgroup]]) {
    const int i = tgpig.x; const int i02 = tgpig.y; const int i03 = tgpig.z;
    const int64_t i1 = ((const device int32_t *)((const device char *)src1 + i*args.nb10 + i02%args.ne11*args.nb11 + i03%args.ne12*args.nb12))[0];
    const int iblk = tiitg;
    if (iblk >= args.nk0) return;
    device const float * src = (device const float *)((const device char *)src0 + i*args.nb01 + i02*args.nb02 + i03*args.nb03) + iblk*256;
    device const int32_t * perm = tq_chmap + (tq_layer_idx * tq_n_kv_heads + iblk) * 256;
    thread float hi_raw[64], lo_raw[192];
    for (int j = 0; j < 64; j++)  hi_raw[j] = src[perm[j]];
    for (int j = 0; j < 192; j++) lo_raw[j] = src[perm[64+j]];
    thread float hi_rot[64], lo_rot[192];
    for (int j = 0; j < 64; j++) hi_rot[j] = hi_raw[j]; tq_fwht<64>(hi_rot);
    for (int j = 0; j < 192; j++) lo_rot[j] = lo_raw[j]; tq_structured_rotate_lo<192, 64>(lo_rot);
    float sum_hi=0, sum_lo=0;
    for (int j=0;j<64;j++) sum_hi+=hi_rot[j]*hi_rot[j];
    for (int j=0;j<192;j++) sum_lo+=lo_rot[j]*lo_rot[j];
    float norm_hi=sqrt(sum_hi), norm_lo=sqrt(sum_lo);
    device block_tqk_3hi_2lo_d256 * blk = (device block_tqk_3hi_2lo_d256 *)((device char *)dst + i1*args.nb1 + i02*args.nb2 + i03*args.nb3) + iblk;
    blk->norm_hi=half(norm_hi); blk->norm_lo=half(norm_lo); blk->rnorm_hi=half(0); blk->rnorm_lo=half(0);
    if (norm_hi==0 && norm_lo==0) {
        for (int j=0;j<24;j++) blk->qs_hi[j]=0; for (int j=0;j<48;j++) blk->qs_lo[j]=0;
        for (int j=0;j<8;j++) blk->signs_hi[j]=0; for (int j=0;j<24;j++) blk->signs_lo[j]=0;
        return;
    }
    float inv_hi=(norm_hi>1e-12f)?1.0f/norm_hi:0, inv_lo=(norm_lo>1e-12f)?1.0f/norm_lo:0;
    for (int j=0;j<24;j++) blk->qs_hi[j]=0;
    for (int j=0;j<64;j++) tq_pk3((device uint8_t*)blk->qs_hi, j, tq_nearest(hi_rot[j]*inv_hi, tq_c8_d64, 8));
    for (int j=0;j<48;j++) blk->qs_lo[j]=0;
    for (int j=0;j<192;j++) tq_pk2((device uint8_t*)blk->qs_lo, j, tq_nearest(lo_rot[j]*inv_lo, tq_c4_d192, 4));
    // QJL on hi
    thread float yhi[64]; for (int j=0;j<64;j++) yhi[j]=tq_c8_d64[tq_up3(blk->qs_hi,j)];
    thread float hi_rec[64]; for (int j=0;j<64;j++) hi_rec[j]=yhi[j]; tq_fwht<64>(hi_rec);
    thread float r_hi[64]; for (int j=0;j<64;j++) r_hi[j]=hi_raw[j]-norm_hi*hi_rec[j];
    float rn_hi=0; for (int j=0;j<64;j++) rn_hi+=r_hi[j]*r_hi[j]; tq_fwht<64>(r_hi);
    for (int j=0;j<8;j++) blk->signs_hi[j]=0;
    for (int j=0;j<64;j++) { if (r_hi[j]>=0) blk->signs_hi[j/8]|=(uint8_t)(1<<(j%8)); }
    blk->rnorm_hi=half(sqrt(rn_hi));
    // QJL on lo (residual in rotated space — per-element sign, no FWHT)
    thread float ylo[192]; for (int j=0;j<192;j++) ylo[j]=tq_c4_d192[tq_up2(blk->qs_lo,j)];
    thread float r_lo[192]; for (int j=0;j<192;j++) r_lo[j]=lo_rot[j]-norm_lo*ylo[j];
    float rn_lo=0; for (int j=0;j<192;j++) rn_lo+=r_lo[j]*r_lo[j];
    for (int j=0;j<24;j++) blk->signs_lo[j]=0;
    for (int j=0;j<192;j++) { if (r_lo[j]>=0) blk->signs_lo[j/8]|=(uint8_t)(1<<(j%8)); }
    blk->rnorm_lo=half(sqrt(rn_lo));
}

// TQK_FLEX: set_rows (quantize f32 input to flex blocks)
// One thread per head (128 dimensions).
// Supports both split (32/96) and non-split (128) modes with
// runtime-configurable bit widths and optional QJL/residual.
[[host_name("kernel_set_rows_flex_i32")]]
kernel void kernel_set_rows_flex(
        constant ggml_metal_kargs_set_rows & args,
        device const void      * src0,
        device const void      * src1,
        device       void      * dst,
        device const int32_t   * tq_chmap,
        constant int32_t & tq_layer_idx,
        constant int32_t & tq_n_kv_heads,
        constant int32_t & flex_hi_bits,
        constant int32_t & flex_lo_bits,
        constant int32_t & flex_hi_res_bits,
        constant int32_t & flex_qjl_hi,
        constant int32_t & flex_qjl_lo,
        constant int32_t & flex_split,
        constant int32_t & flex_block_bytes,
        uint3 tgpig[[threadgroup_position_in_grid]],
        ushort tiitg[[thread_index_in_threadgroup]]) {
    const int i   = tgpig.x;
    const int i02 = tgpig.y;
    const int i03 = tgpig.z;
    const int64_t i1 = ((const device int32_t *)((const device char *)src1 + i*args.nb10 + i02%args.ne11*args.nb11 + i03%args.ne12*args.nb12))[0];
    const int iblk = tiitg;
    if (iblk >= args.nk0) return;

    device const float * src = (device const float *)((const device char *)src0 + i*args.nb01 + i02*args.nb02 + i03*args.nb03) + iblk * 128;
    const int blk_stride = args.nb1 / args.nk0; // per-head stride in dst (may be > flex_block_bytes for per-layer flex)
    device uint8_t * blk = (device uint8_t *)((device char *)dst + i1*args.nb1 + i02*args.nb2 + i03*args.nb3) + iblk * blk_stride;

    if (flex_split) {
        // --- SPLIT MODE: 32 hi channels + 96 lo channels ---
        device const int32_t * perm = tq_chmap + (tq_layer_idx * tq_n_kv_heads + iblk) * 128;

        // Read and permute source data
        thread float hi_raw[32], lo_raw[96];
        for (int j = 0; j < 32; j++)  hi_raw[j] = src[perm[j]];
        for (int j = 0; j < 96; j++)  lo_raw[j] = src[perm[32 + j]];

        // Rotate: FWHT_32 on hi, bare 3xFWHT_32 on lo
        thread float hi_rot[32], lo_rot[96];
        for (int j = 0; j < 32; j++) hi_rot[j] = hi_raw[j];
        tq_fwht<32>(hi_rot);
        for (int j = 0; j < 96; j++) lo_rot[j] = lo_raw[j];
        tq_fwht<32>(lo_rot); tq_fwht<32>(lo_rot + 32); tq_fwht<32>(lo_rot + 64);

        // Compute norms
        float sum_hi = 0.0f, sum_lo = 0.0f;
        for (int j = 0; j < 32; j++) sum_hi += hi_rot[j] * hi_rot[j];
        for (int j = 0; j < 96; j++) sum_lo += lo_rot[j] * lo_rot[j];
        float norm_hi = sqrt(sum_hi), norm_lo = sqrt(sum_lo);

        // Compute field offsets (mirrors dequant layout)
        int off = 0;
        // norm_hi, norm_lo
        *(device half *)(blk + 0) = half(norm_hi);
        *(device half *)(blk + 2) = half(norm_lo);
        off = 4;

        int off_qs_hi = off;
        int qs_hi_bytes = (32 * flex_hi_bits + 7) / 8;
        off += qs_hi_bytes;

        int off_qs_lo = off;
        int qs_lo_bytes = (96 * flex_lo_bits + 7) / 8;
        off += qs_lo_bytes;

        int off_rnorm_res = off;
        int off_qs_hi2 = off + 2;
        int qs_hi2_bytes = (32 * flex_hi_res_bits + 7) / 8;
        if (flex_hi_res_bits > 0) {
            off += 2 + qs_hi2_bytes;
        }

        int off_rnorm_qjl_hi = off;
        int off_signs_hi = off + 2;
        if (flex_qjl_hi) {
            off += 2 + 4;
        }

        int off_rnorm_qjl_lo = off;
        int off_signs_lo = off + 2;

        // Handle zero-norm case: zero out the entire block
        if (norm_hi == 0.0f && norm_lo == 0.0f) {
            for (int j = 4; j < flex_block_bytes; j++) blk[j] = 0;
            return;
        }

        float inv_hi = (norm_hi > 1e-12f) ? 1.0f / norm_hi : 0.0f;
        float inv_lo = (norm_lo > 1e-12f) ? 1.0f / norm_lo : 0.0f;

        // --- Quantize hi: nearest centroid in d=32 space ---
        for (int j = 0; j < qs_hi_bytes; j++) blk[off_qs_hi + j] = 0;
        for (int j = 0; j < 32; j++) {
            int idx = flex_nearest_d32(hi_rot[j] * inv_hi, flex_hi_bits);
            flex_pack_metal(blk + off_qs_hi, j, idx, flex_hi_bits);
        }

        // --- Quantize lo: nearest centroid in d=96 space ---
        for (int j = 0; j < qs_lo_bytes; j++) blk[off_qs_lo + j] = 0;
        for (int j = 0; j < 96; j++) {
            int idx = flex_nearest_d96(lo_rot[j] * inv_lo, flex_lo_bits);
            flex_pack_metal(blk + off_qs_lo, j, idx, flex_lo_bits);
        }

        // --- Optional: hi residual MSE ---
        if (flex_hi_res_bits > 0) {
            // Compute residual in rotated space
            thread float r1[32];
            float rnorm_sq = 0.0f;
            for (int j = 0; j < 32; j++) {
                int v = flex_unpack_metal(blk + off_qs_hi, j, flex_hi_bits);
                r1[j] = hi_rot[j] - norm_hi * flex_centroid_d32(v, flex_hi_bits);
                rnorm_sq += r1[j] * r1[j];
            }
            float rnorm2 = sqrt(rnorm_sq);
            float inv_rn = (rnorm2 > 1e-12f) ? 1.0f / rnorm2 : 0.0f;

            for (int j = 0; j < qs_hi2_bytes; j++) blk[off_qs_hi2 + j] = 0;
            for (int j = 0; j < 32; j++) {
                int idx = flex_nearest_d32(r1[j] * inv_rn, flex_hi_res_bits);
                flex_pack_metal(blk + off_qs_hi2, j, idx, flex_hi_res_bits);
            }
            *(device half *)(blk + off_rnorm_res) = half(rnorm2);
        }

        // --- Optional: QJL on hi ---
        if (flex_qjl_hi) {
            // Reconstruct hi from quantized indices (in rotated space)
            thread float yhi[32];
            for (int j = 0; j < 32; j++) {
                yhi[j] = flex_centroid_d32(
                    flex_unpack_metal(blk + off_qs_hi, j, flex_hi_bits), flex_hi_bits);
            }
            // If residual was used, add it to reconstruction
            if (flex_hi_res_bits > 0) {
                float rn2 = float(*(device const half *)(blk + off_rnorm_res));
                float inv_norm_for_res = (norm_hi > 1e-12f) ? rn2 / norm_hi : 0.0f;
                for (int j = 0; j < 32; j++) {
                    yhi[j] += inv_norm_for_res * flex_centroid_d32(
                        flex_unpack_metal(blk + off_qs_hi2, j, flex_hi_res_bits), flex_hi_res_bits);
                }
            }

            // FWHT to get back to raw space
            thread float hi_rec[32];
            for (int j = 0; j < 32; j++) hi_rec[j] = yhi[j];
            tq_fwht<32>(hi_rec);

            // Residual in raw space
            thread float r_hi[32];
            float rnorm_sq = 0.0f;
            for (int j = 0; j < 32; j++) {
                r_hi[j] = hi_raw[j] - norm_hi * hi_rec[j];
                rnorm_sq += r_hi[j] * r_hi[j];
            }

            // FWHT of residual to get sign bits in rotated space
            tq_fwht<32>(r_hi);
            for (int j = 0; j < 4; j++) blk[off_signs_hi + j] = 0;
            for (int j = 0; j < 32; j++) {
                if (r_hi[j] >= 0.0f) {
                    blk[off_signs_hi + j / 8] |= (uint8_t)(1 << (j % 8));
                }
            }
            *(device half *)(blk + off_rnorm_qjl_hi) = half(sqrt(rnorm_sq));
        }

        // --- Optional: QJL on lo ---
        if (flex_qjl_lo) {
            // Residual in rotated space (per-element sign, no FWHT on correction)
            thread float ylo[96];
            for (int j = 0; j < 96; j++) {
                ylo[j] = flex_centroid_d96(
                    flex_unpack_metal(blk + off_qs_lo, j, flex_lo_bits), flex_lo_bits);
            }
            thread float r_lo[96];
            float rn_lo = 0.0f;
            for (int j = 0; j < 96; j++) {
                r_lo[j] = lo_rot[j] - norm_lo * ylo[j];
                rn_lo += r_lo[j] * r_lo[j];
            }
            for (int j = 0; j < 12; j++) blk[off_signs_lo + j] = 0;
            for (int j = 0; j < 96; j++) {
                if (r_lo[j] >= 0.0f) {
                    blk[off_signs_lo + j / 8] |= (uint8_t)(1 << (j % 8));
                }
            }
            *(device half *)(blk + off_rnorm_qjl_lo) = half(sqrt(rn_lo));
        }
    } else {
        // --- NON-SPLIT MODE: full 128-dim FWHT ---
        thread float vals[128];
        float sum_sq = 0.0f;
        for (int j = 0; j < 128; j++) {
            vals[j] = src[j];
            sum_sq += vals[j] * vals[j];
        }
        float norm = sqrt(sum_sq);

        // norm
        *(device half *)(blk) = half(norm);
        int off = 2;

        int off_qs = off;
        int qs_bytes = (128 * flex_hi_bits + 7) / 8;
        off += qs_bytes;

        int off_rnorm_qjl = off;
        int off_signs = off + 2;

        if (norm == 0.0f) {
            for (int j = 2; j < flex_block_bytes; j++) blk[j] = 0;
            return;
        }

        float inv = 1.0f / norm;

        // Rotate via FWHT_128
        thread float rot[128];
        for (int j = 0; j < 128; j++) rot[j] = vals[j] * inv;
        tq_fwht<128>(rot);

        // Quantize: nearest centroid in d=128 space
        for (int j = 0; j < qs_bytes; j++) blk[off_qs + j] = 0;
        for (int j = 0; j < 128; j++) {
            int idx = flex_nearest_d128(rot[j], flex_hi_bits);
            flex_pack_metal(blk + off_qs, j, idx, flex_hi_bits);
        }

        // Optional: QJL on full 128-dim
        if (flex_qjl_hi) {
            // Reconstruct in rotated space, then FWHT to raw space
            thread float recon[128];
            for (int j = 0; j < 128; j++) {
                recon[j] = flex_centroid_d128(
                    flex_unpack_metal(blk + off_qs, j, flex_hi_bits), flex_hi_bits);
            }
            tq_fwht<128>(recon);

            // Residual in raw space
            thread float resid[128];
            float rnorm_sq = 0.0f;
            for (int j = 0; j < 128; j++) {
                resid[j] = vals[j] - norm * recon[j];
                rnorm_sq += resid[j] * resid[j];
            }

            // FWHT of residual for sign bits
            tq_fwht<128>(resid);
            int signs_bytes = 128 / 8;
            for (int j = 0; j < signs_bytes; j++) blk[off_signs + j] = 0;
            for (int j = 0; j < 128; j++) {
                if (resid[j] >= 0.0f) {
                    blk[off_signs + j / 8] |= (uint8_t)(1 << (j % 8));
                }
            }
            *(device half *)(blk + off_rnorm_qjl) = half(sqrt(rnorm_sq));
        }
    }
}


