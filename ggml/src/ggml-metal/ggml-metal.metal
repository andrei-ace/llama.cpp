// 5r3_sj (tqk5r3_sj): 5-bit MSE + 3-bit residual on hi, 3-bit MSE on lo (no QJL)
template <typename type4x4>
void dequantize_5r3_sj(device const block_tqk_5r3_sj * xb, short il, thread type4x4 & reg) {
    float4x4 reg_f;
    for (int i = 0; i < 16; i++) {
        int j = il * 16 + i;
        if (j < 32) {
            float norm_hi = float(xb->norm_hi);
            float rnorm2  = float(xb->rnorm2_hi);
            int v1 = tq_up5(xb->qs_hi, j);
            int v2 = tq_up3(xb->qs_hi2, j);
            reg_f[i/4][i%4] = norm_hi * tq_c32_d32[v1] + rnorm2 * tq_c8_d32[v2];
        } else {
            float norm_lo = float(xb->norm_lo);
            int lo_j = j - 32;
            reg_f[i/4][i%4] = norm_lo * tq_c8_d96[tq_up3(xb->qs_lo, lo_j)];
        }
    }
    reg = (type4x4) reg_f;
